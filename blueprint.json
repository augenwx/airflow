    ],
    "recommended_behavior": "Usar botones superiores o panel lateral izquierdo. Mantener filtros sincronizados por mercado y contrato cuando sea posible."
  },
  "build_steps": [
    {
      "step": 1,
      "title": "Conectar datos",
      "details": "En Power BI Desktop, Obtener datos > ODBC > seleccionar DSN de DuckDB. Cargar las 11 tablas del esquema main_marts."
    },
    {
      "step": 2,
      "title": "Crear dimensiones",
      "details": "Crear dim_market, dim_contract y dim_date para evitar relaciones many-to-many entre marts."
    },
    {
      "step": 3,
      "title": "Crear medidas",
      "details": "Crear tabla _Measures y agregar las medidas DAX definidas en dax_measures."
    },
    {
      "step": 4,
      "title": "Crear páginas",
      "details": "Crear las cuatro páginas con tamaño 16:9. Usar fondo oscuro #0B1020 y paneles #111827."
    },
    {
      "step": 5,
      "title": "Agregar visuales",
      "details": "Usar el arreglo pages[].visuals como guía exacta de visual, campos, filtros, posiciones y formato."
    },
    {
      "step": 6,
      "title": "Validar filtros",
      "details": "Probar filtros por market_name, contract_name, date, direction y signal_strength. Verificar que no se filtren tablas incorrectamente por relaciones ambiguas."
    },
    {
      "step": 7,
      "title": "Guardar",
      "details": "Guardar primero como .pbix. Luego guardar como Power BI Project (.pbip) si se quiere editar internamente/versionar en Git."
    }
  ],
  "quality_rules": [
    "No saturar una sola página con todos los marts.",
    "Cada página debe responder una pregunta analítica distinta.",
    "Usar mart_market_snapshot para estado actual, no fct_contract_prices.",
    "Usar fct_contract_prices solo para auditoría o detalle granular.",
    "Usar mart_price_trends y mart_rolling_averages para líneas históricas, no la tabla base completa.",
    "Usar mart_anomaly_detection como fuente principal para alertas.",
    "Usar mart_spread_analysis para liquidez y mart_volatility_analysis para riesgo de precio.",
    "Mantener formatos porcentuales en precios, cambios y spreads.",
    "Aplicar formato condicional: verde para subidas, rojo para caídas/anomalías, naranja para riesgo medio."
  ],
  "expected_user_experience": {
    "overview": "El usuario abre el reporte y ve inmediatamente cuántos mercados/contratos hay, precio promedio, mayor gainer, mayor loser, anomalías y spreads.",
    "trends": "El usuario analiza evolución histórica y detecta movimientos sostenidos o cambios bruscos.",
    "risk": "El usuario identifica contratos anómalos, volátiles o con baja liquidez.",
    "contract_detail": "El usuario selecciona un contrato y ve su evolución, promedios, spreads, anomalías y eventos relevantes."
  }
