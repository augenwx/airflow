{
  "project": {
    "name": "PredictIt Executive Analytics Dashboard",
    "version": "1.0.0",
    "language": "es",
    "description": "Blueprint completo para construir un dashboard de Power BI sobre los marts de PredictIt almacenados en DuckDB/Parquet. Este archivo describe modelo, medidas DAX, páginas, visuales, layouts, filtros, colores y reglas de diseño.",
    "important_note": "Este JSON NO es un archivo PBIX/PBIP oficial importable directamente por Power BI. Es una especificación técnica para replicar el dashboard manualmente o para usarla como base en automatización con PBIP/TMDL/Tabular Editor/Fabric APIs."
  },
  "data_source": {
    "type": "DuckDB via ODBC",
    "recommended_connection_name": "duckdb_predictit",
    "database_file_example": "D:/mineria data/airflow/data/warehouse/predictit.duckdb",
    "schema": "main_marts",
    "load_mode_recommendation": "Import",
    "refresh_recommendation": "Actualizar después de cada corrida estable de Airflow. Evitar que Power BI lea el mismo archivo .duckdb mientras Airflow lo escribe.",
    "tables_to_load": [
      "main_marts.fct_contract_prices",
      "main_marts.mart_market_snapshot",
      "main_marts.mart_contract_leaders",
      "main_marts.mart_top_movers",
      "main_marts.mart_price_trends",
      "main_marts.mart_rolling_averages",
      "main_marts.mart_candidate_momentum",
      "main_marts.mart_turning_points",
      "main_marts.mart_volatility_analysis",
      "main_marts.mart_spread_analysis",
      "main_marts.mart_anomaly_detection"
    ],
    "recommended_power_query_steps": [
      "Conectar mediante ODBC al DSN duckdb_predictit.",
      "Cargar todas las tablas del esquema main_marts.",
      "Renombrar tablas para presentación: quitar prefijos fct_ y mart_ si se desea.",
      "Verificar tipos: extraction_ts como Date/Time, snapshot_date como Date, precios/spreads/z_score como Decimal Number, is_anomaly como True/False.",
      "Crear dimensiones dim_market, dim_contract y dim_date en Power Query o DAX."
    ]
  },
  "theme": {
    "name": "Dark Executive BI",
    "canvas": {
      "width": 1280,
      "height": 720,
      "background": "#0B1020"
    },
    "colors": {
      "background": "#0B1020",
      "panel": "#111827",
      "panel_alt": "#172033",
      "border": "#253047",
      "text_primary": "#F8FAFC",
      "text_secondary": "#CBD5E1",
      "muted": "#94A3B8",
      "accent_blue": "#38BDF8",
      "accent_green": "#22C55E",
      "accent_red": "#EF4444",
      "accent_orange": "#F97316",
      "accent_yellow": "#EAB308",
      "accent_purple": "#A855F7"
    },
    "fonts": {
      "title": "Segoe UI Semibold",
      "body": "Segoe UI",
      "number": "Segoe UI Semibold"
    },
    "formatting_rules": {
      "positive_change": "#22C55E",
      "negative_change": "#EF4444",
      "neutral": "#94A3B8",
      "anomaly_true": "#EF4444",
      "anomaly_false": "#22C55E",
      "high_risk": "#EF4444",
      "medium_risk": "#F97316",
      "low_risk": "#22C55E"
    }
  },
  "model": {
    "recommended_star_schema": {
      "fact_tables": [
        "fct_contract_prices"
      ],
      "mart_tables": [
        "mart_market_snapshot",
        "mart_contract_leaders",
        "mart_top_movers",
        "mart_price_trends",
        "mart_rolling_averages",
        "mart_candidate_momentum",
        "mart_turning_points",
        "mart_volatility_analysis",
        "mart_spread_analysis",
        "mart_anomaly_detection"
      ],
      "dimensions_to_create": [
        {
          "name": "dim_market",
          "source_logic": "UNION DISTINCT market_id, market_name desde todos los marts donde existan esos campos.",
          "columns": ["market_id", "market_name"]
        },
        {
          "name": "dim_contract",
          "source_logic": "UNION DISTINCT contract_id, contract_name, market_id, market_name desde todos los marts donde existan esos campos.",
          "columns": ["contract_id", "contract_name", "market_id", "market_name"]
        },
        {
          "name": "dim_date",
          "source_logic": "CALENDAR desde MIN fecha de fct_contract_prices[extraction_ts] hasta MAX fecha de fct_contract_prices[extraction_ts].",
          "columns": ["date", "year", "quarter", "month", "month_name", "day", "weekday", "is_weekend"]
        }
      ]
    },
    "relationships": [
      {
        "from": "dim_market[market_id]",
        "to": "mart_market_snapshot[market_id]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_market[market_id]",
        "to": "mart_contract_leaders[market_id]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_market[market_id]",
        "to": "mart_top_movers[market_id]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_market[market_id]",
        "to": "mart_anomaly_detection[market_id]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_market[market_id]",
        "to": "mart_volatility_analysis[market_id]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_market[market_id]",
        "to": "mart_spread_analysis[market_id]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_contract[contract_id]",
        "to": "fct_contract_prices[contract_id]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_contract[contract_id]",
        "to": "mart_price_trends[contract_id]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_contract[contract_id]",
        "to": "mart_rolling_averages[contract_id]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_contract[contract_id]",
        "to": "mart_candidate_momentum[contract_id]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_contract[contract_id]",
        "to": "mart_turning_points[contract_id]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_date[date]",
        "to": "mart_price_trends[snapshot_date]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_date[date]",
        "to": "mart_rolling_averages[snapshot_date]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      },
      {
        "from": "dim_date[date]",
        "to": "mart_turning_points[snapshot_date]",
        "cardinality": "one-to-many",
        "filter_direction": "single"
      }
    ],
    "avoid_relationships": [
      "No relacionar mart_top_movers directamente con mart_contract_leaders.",
      "No relacionar mart_anomaly_detection directamente con mart_volatility_analysis.",
      "No crear relaciones many-to-many si se puede resolver mediante dim_market y dim_contract.",
      "No conectar todos los marts entre sí por contract_name; usar contract_id."
    ]
  },
  "dax_measures": [
    {
      "name": "Total Markets",
      "table": "_Measures",
      "expression": "DISTINCTCOUNT(mart_market_snapshot[market_id])",
      "format": "#,0",
      "description": "Cantidad de mercados activos en el último snapshot cargado."
    },
    {
      "name": "Total Contracts",
      "table": "_Measures",
      "expression": "DISTINCTCOUNT(mart_market_snapshot[contract_id])",
      "format": "#,0",
      "description": "Cantidad de contratos activos en el último snapshot cargado."
    },
    {
      "name": "Avg Current Price",
      "table": "_Measures",
      "expression": "AVERAGE(mart_market_snapshot[last_trade_price])",
      "format": "0.00%",
      "description": "Precio promedio actual."
    },
    {
      "name": "Max 24h Gain",
      "table": "_Measures",
      "expression": "MAX(mart_top_movers[change_pct])",
      "format": "+0.00%;-0.00%;0.00%",
      "description": "Mayor cambio positivo de 24 horas."
    },
    {
      "name": "Max 24h Loss",
      "table": "_Measures",
      "expression": "MIN(mart_top_movers[change_pct])",
      "format": "+0.00%;-0.00%;0.00%",
      "description": "Mayor caída de 24 horas."
    },
    {
      "name": "Active Anomalies",
      "table": "_Measures",
      "expression": "COUNTROWS(FILTER(mart_anomaly_detection, mart_anomaly_detection[is_anomaly] = TRUE()))",
      "format": "#,0",
      "description": "Número de anomalías activas detectadas."
    },
    {
      "name": "Avg Spread Yes",
      "table": "_Measures",
      "expression": "AVERAGE(mart_spread_analysis[current_spread_yes])",
      "format": "0.00%",
      "description": "Spread YES promedio actual."
    },
    {
      "name": "Max Spread Yes",
      "table": "_Measures",
      "expression": "MAX(mart_spread_analysis[current_spread_yes])",
      "format": "0.00%",
      "description": "Spread YES máximo actual."
    },
    {
      "name": "Avg Volatility Score",
      "table": "_Measures",
      "expression": "AVERAGE(mart_volatility_analysis[volatility_score])",
      "format": "0.000",
      "description": "Score promedio de volatilidad."
    },
    {
      "name": "Extreme Z Score",
      "table": "_Measures",
      "expression": "MAXX(mart_anomaly_detection, ABS(mart_anomaly_detection[z_score]))",
      "format": "0.00",
      "description": "Z-score extremo absoluto."
    },
    {
      "name": "Avg 7D",
      "table": "_Measures",
      "expression": "AVERAGE(mart_rolling_averages[avg_7d])",
      "format": "0.00%",
      "description": "Promedio móvil de 7 días."
    },
    {
      "name": "Avg 14D",
      "table": "_Measures",
      "expression": "AVERAGE(mart_rolling_averages[avg_14d])",
      "format": "0.00%",
      "description": "Promedio móvil de 14 días."
    },
    {
      "name": "Avg 30D",
      "table": "_Measures",
      "expression": "AVERAGE(mart_rolling_averages[avg_30d])",
      "format": "0.00%",
      "description": "Promedio móvil de 30 días."
    },
    {
      "name": "Current Contract Price",
      "table": "_Measures",
      "expression": "MAX(mart_market_snapshot[last_trade_price])",
      "format": "0.00%",
      "description": "Precio actual del contrato seleccionado."
    },
    {
      "name": "Contract Change 24h",
      "table": "_Measures",
      "expression": "MAX(mart_top_movers[change_pct])",
      "format": "+0.00%;-0.00%;0.00%",
      "description": "Cambio 24h del contrato seleccionado."
    },
    {
      "name": "Observation Count",
      "table": "_Measures",
      "expression": "SUM(mart_price_trends[observations])",
      "format": "#,0",
      "description": "Número de observaciones agregadas."
    },
    {
      "name": "Significant Turning Points",
      "table": "_Measures",
      "expression": "COUNTROWS(FILTER(mart_turning_points, mart_turning_points[is_significant] = TRUE()))",
      "format": "#,0",
      "description": "Cantidad de puntos de giro significativos."
    },
    {
      "name": "Liquidity Risk Score",
      "table": "_Measures",
      "expression": "AVERAGE(mart_spread_analysis[spread_volatility_ratio])",
      "format": "0.00",
      "description": "Indicador agregado de riesgo de liquidez basado en spread/volatilidad."
    }
  ],
  "calculated_columns": [
    {
      "table": "mart_top_movers",
      "name": "Change Direction Label",
      "expression": "IF(mart_top_movers[change_pct] > 0, \"GAINER\", IF(mart_top_movers[change_pct] < 0, \"LOSER\", \"FLAT\"))"
    },
    {
      "table": "mart_anomaly_detection",
      "name": "Anomaly Label",
      "expression": "IF(mart_anomaly_detection[is_anomaly] = TRUE(), \"ANOMALY\", \"NORMAL\")"
    },
    {
      "table": "mart_volatility_analysis",
      "name": "Risk Bucket",
      "expression": "SWITCH(TRUE(), mart_volatility_analysis[volatility_score] >= 0.80, \"High\", mart_volatility_analysis[volatility_score] >= 0.50, \"Medium\", \"Low\")"
    }
  ],
