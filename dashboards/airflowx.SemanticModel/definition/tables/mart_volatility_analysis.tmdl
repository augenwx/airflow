		lineageTag: afbe7d8e-8e9f-0a1b-2c3d-4e5f6a7b8c9d
		summarizeBy: none
		sourceColumn: market_id

		annotation SummarizationSetBy = Automatic

	column market_name
		dataType: string
		lineageTag: bacf8e9f-9f0a-1b2c-3d4e-5f6a7b8c9d0e
		summarizeBy: none
		sourceColumn: market_name

		annotation SummarizationSetBy = Automatic

	column window_days
		dataType: int64
		formatString: 0
		lineageTag: cbda9f0a-0a1b-2c3d-4e5f-6a7b8c9d0e1f
		summarizeBy: sum
		sourceColumn: window_days

		annotation SummarizationSetBy = Automatic

	column avg_price
		dataType: double
		lineageTag: dceb0a1b-1b2c-3d4e-5f6a-7b8c9d0e1f2a
		summarizeBy: sum
		sourceColumn: avg_price

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column stddev_price
		dataType: double
		lineageTag: edfc1b2c-2c3d-4e5f-6a7b-8c9d0e1f2a3b
		summarizeBy: sum
		sourceColumn: stddev_price

		annotation SummarizationSetBy = Automatic

