table mart_volatility_analysis
	lineageTag: bacf2e3f-3f4a-5b6c-7d8e-9f0a1b2c3d4e

	measure 'Avg Volatility' = AVERAGE(mart_volatility_analysis[volatility_score])
		formatString: 0.00
		lineageTag: cbda3f4a-4a5b-6c7d-8e9f-0a1b2c3d4e5f

	measure 'Max Volatility Contract' = CALCULATE(MAX(mart_volatility_analysis[contract_name]), TOPN(1, ALL(mart_volatility_analysis), mart_volatility_analysis[volatility_score], DESC))
		lineageTag: dceb4a5b-5b6c-7d8e-9f0a-1b2c3d4e5f6a

	measure 'Volatilidad Máxima 30d' = MAXX(FILTER(mart_volatility_analysis, mart_volatility_analysis[window_days] = 30), mart_volatility_analysis[volatility_score])
		formatString: 0.000
		lineageTag: 3d444444-4444-4444-8444-444444444441

	measure 'Volatility Score' = MAX(mart_volatility_analysis[volatility_score])
		formatString: 0.000
		lineageTag: 3d444444-4444-4444-8444-444444444442

	column contract_id
		dataType: string
		lineageTag: edfc5b6c-6c7d-8e9f-0a1b-2c3d4e5f6a7b
		summarizeBy: none
		sourceColumn: contract_id

		annotation SummarizationSetBy = Automatic

	column contract_name
		dataType: string
		lineageTag: fead6c7d-7d8e-9f0a-1b2c-3d4e5f6a7b8c
		summarizeBy: none
		sourceColumn: contract_name

		annotation SummarizationSetBy = Automatic

	column market_id
