	column extraction_ts
		dataType: dateTime
		formatString: General Date
		lineageTag: cbda5f6a-6a7b-8c9d-0e1f-2a3b4c5d6e7f
		summarizeBy: none
		sourceColumn: extraction_ts

		annotation SummarizationSetBy = Automatic

	partition mart_volatility_analysis = m
		mode: import
		source =
				let
				    Origen = Odbc.DataSource("dsn=duckdb2", [HierarchicalNavigation=true]),
				    predictit_Database = Origen{[Name="predictit",Kind="Database"]}[Data],
				    main_marts_Schema = predictit_Database{[Name="main_marts",Kind="Schema"]}[Data],
				    mart_volatility_analysis_Table = main_marts_Schema{[Name="mart_volatility_analysis",Kind="Table"]}[Data]
				in
				    mart_volatility_analysis_Table

	annotation PBI_ResultType = Table

