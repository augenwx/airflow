	partition dim_contract = m
		mode: import
		source =
				let
				    Origen = Odbc.DataSource("dsn=duckdb2", [HierarchicalNavigation=true]),
				    predictit_Database = Origen{[Name="predictit",Kind="Database"]}[Data],
				    main_marts_Schema = predictit_Database{[Name="main_marts",Kind="Schema"]}[Data],
				    mart_market_snapshot_Table = main_marts_Schema{[Name="mart_market_snapshot",Kind="Table"]}[Data],
				    dim_contract_Table = Table.Distinct(Table.SelectColumns(mart_market_snapshot_Table, {"contract_id", "contract_name", "market_id"}))
				in
				    dim_contract_Table

	annotation PBI_ResultType = Table

